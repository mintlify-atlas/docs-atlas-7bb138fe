  "keyFeatures": [
    "Selling plan group management with flexible delivery and pricing options",
    "Subscription contract lifecycle management (create, pause, resume, cancel)",
    "Automated billing cycle processing with dunning management",
    "Customer-facing subscription management portal with UI extensions",
    "Admin extensions for managing subscriptions from the Shopify admin",
    "Webhook integration for subscription lifecycle events",
    "Job scheduling system for background processing (billing, dunning, emails)",
    "Multi-locale support with translation management",
    "Inventory tracking and validation for subscription products",
    "Flexible payment method update workflows"
  ],
